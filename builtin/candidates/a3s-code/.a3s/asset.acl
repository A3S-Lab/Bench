version = "a3s.asset.v1"
category = "agent"
kind = "tool"
name = "a3s-code"
description = "Bundled A3S Code controller for model comparisons."
service = "Coding Agent"
created_by = "a3s-bench"

source {
  package_path = "."
  entrypoint = "run.sh"
  definition_path = "prompts/controller.md"
}

metadata {
  asset_acl_path = ".a3s/asset.acl"
}

runtime {
  kind = "tool"
  isolation = "serving"
  runtime_kind = "a3s-code"
  protocol = "agent-tool"
  agent_kind = "coding-agent"
}
