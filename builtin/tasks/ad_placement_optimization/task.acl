# Third-party source details: ../../provenance/edgebench.json
bench "ad_placement_optimization" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Ad Placement Optimization"
  category    = "Combinatorial Optimization"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.ad_placement_optimization:49747cad3ebd"
      platform    = "linux/amd64"
      source_path = "/home/workspace/ad-placement"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.ad_placement_optimization:49747cad3ebd"
    }
    network_need = "none"
  }

  submission {
    include = [
      "solution.cpp",
    ]
    exclude = [
      "tests",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 600
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
