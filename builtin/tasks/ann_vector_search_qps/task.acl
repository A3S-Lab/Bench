# Third-party source details: ../../provenance/edgebench.json
bench "ann_vector_search_qps" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Ann Vector Search Qps"
  category    = "Systems & Software Engineering"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.ann_vector_search_qps:74bf3ba9a919"
      platform    = "linux/amd64"
      source_path = "/home/workspace/ann-benchmarks"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.ann_vector_search_qps:74bf3ba9a919"
    }
    network_need = "none"
  }

  submission {
    include = [
      "ann_benchmarks/algorithms/custom/",
    ]
    exclude = [
      "tests",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 7800
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
