{
  "admission": "quarantined",
  "evaluation": {
    "mode": "batch",
    "source_command": "python3 /tmp/eval_wesnoth.py",
    "source_game_server_command": null,
    "timeout_sec": 900
  },
  "image": {
    "digest_resolution": "required_at_task_lock",
    "platform": "linux/amd64",
    "ref": "docker.io/seededge/edgebench.judge.wesnoth_tactical_ai:2856cf56b832"
  },
  "kind": "oci",
  "requirements": [
    "oci_judge_admission"
  ],
  "schema": "a3s-bench/judge-source/v1",
  "source_result": {
    "kind": "legacy_stdout",
    "parser": "score_sum",
    "rescale_hint": {
      "kind": "linear",
      "lower": 0.0,
      "upper": 100.0
    },
    "score_direction": "maximize",
    "selection_hint": "score_first",
    "target_metric": "score"
  },
  "workspace": {
    "source_path": "/home/wesnoth_agent",
    "submission_exclude": [
      ".git"
    ],
    "submission_paths": [
      "."
    ]
  }
}
