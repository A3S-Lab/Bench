# Third-party source details: ../../provenance/edgebench.json
bench "wesnoth_tactical_ai" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Wesnoth Tactical Ai"
  category    = "Interactive Games & Simulators"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.wesnoth_tactical_ai:43d1943974c7"
      platform    = "linux/amd64"
      source_path = "/home/wesnoth_agent"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.wesnoth_tactical_ai:43d1943974c7"
    }
    network_need = "none"
  }

  submission {
    include = [
      ".",
    ]
    exclude = [
      ".git",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 900
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
