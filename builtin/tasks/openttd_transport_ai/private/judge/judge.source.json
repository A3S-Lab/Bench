{
  "admission": "quarantined",
  "evaluation": {
    "mode": "batch",
    "source_command": "cd /home/workspace/openttd_ai && OPENTTD_N_SEEDS=5 python3 /tmp/eval_openttd.py",
    "source_game_server_command": null,
    "timeout_sec": 3600
  },
  "image": {
    "digest_resolution": "required_at_task_lock",
    "platform": "linux/amd64",
    "ref": "docker.io/seededge/edgebench.judge.openttd_transport_ai:ef9ac9e95c29"
  },
  "kind": "oci",
  "requirements": [
    "oci_judge_admission"
  ],
  "schema": "a3s-bench/judge-source/v1",
  "source_result": {
    "kind": "legacy_stdout",
    "parser": "score_sum",
    "rescale_hint": {
      "baseline": 100000.0,
      "expert": 1000000000.0,
      "kind": "log_max"
    },
    "score_direction": "maximize",
    "selection_hint": "score_first",
    "target_metric": "score"
  },
  "workspace": {
    "source_path": "/home/workspace/openttd_ai",
    "submission_exclude": [
      "tests"
    ],
    "submission_paths": [
      "my_ai/"
    ]
  }
}
