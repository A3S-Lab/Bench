# Third-party source details: ../../provenance/edgebench.json
bench "openrct2_theme_park_ai" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Openrct2 Theme Park Ai"
  category    = "Interactive Games & Simulators"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.openrct2_theme_park_ai:7283790ee698"
      platform    = "linux/amd64"
      source_path = "/home/workspace/openrct2"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.openrct2_theme_park_ai:7283790ee698"
    }
    network_need = "none"
  }

  submission {
    include = [
      "my_plugin.js",
    ]
    exclude = [
      "tests",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 2400
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
