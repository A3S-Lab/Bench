{
  "admission": "quarantined",
  "evaluation": {
    "mode": "batch",
    "source_command": "cd /home/workspace/openrct2 && OPENRCT2_TIMEOUT=120 python3 /tmp/eval_openrct2.py",
    "source_game_server_command": null,
    "timeout_sec": 2400
  },
  "image": {
    "digest_resolution": "required_at_task_lock",
    "platform": "linux/amd64",
    "ref": "docker.io/seededge/edgebench.judge.openrct2_theme_park_ai:80316ccd77ae"
  },
  "kind": "oci",
  "requirements": [
    "oci_judge_admission"
  ],
  "schema": "a3s-bench/judge-source/v1",
  "source_result": {
    "kind": "legacy_stdout",
    "parser": "score_sum",
    "rescale_hint": {
      "kind": "linear",
      "lower": 0.0,
      "upper": 40000.0
    },
    "score_direction": "maximize",
    "selection_hint": "score_first",
    "target_metric": "score"
  },
  "workspace": {
    "source_path": "/home/workspace/openrct2",
    "submission_exclude": [
      "tests"
    ],
    "submission_paths": [
      "my_plugin.js"
    ]
  }
}
