# Third-party source details: ../../provenance/edgebench.json
bench "arc_compiler_runtime" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Arc Compiler Runtime"
  category    = "Systems & Software Engineering"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.arc_compiler_runtime:c92a7b116597"
      platform    = "linux/amd64"
      source_path = "/home/workspace/arc-compiler-runtime-implementation/agent-start"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.arc_compiler_runtime:c92a7b116597"
    }
    network_need = "none"
  }

  submission {
    include = [
      "compiler/src/",
    ]
    exclude = [
      "compiler/dist",
      "tests",
      "node_modules",
      ".git",
      ".github",
      ".DS_Store",
      "*.map",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 1500
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
