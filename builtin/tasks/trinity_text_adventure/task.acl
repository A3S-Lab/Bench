# Third-party source details: ../../provenance/edgebench.json
bench "trinity_text_adventure" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Trinity Text Adventure"
  category    = "Interactive Games & Simulators"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.trinity_text_adventure:61ded5caecc2"
      platform    = "linux/amd64"
      source_path = "/home/jericho_agent"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.trinity_text_adventure:61ded5caecc2"
    }
    network_need = "none"
  }

  submission {
    include = []
    exclude = [
      "tests",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 600
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
