# Third-party source details: ../../provenance/edgebench.json
bench "vibrating_path_graph_coloring" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Vibrating Path Graph Coloring"
  category    = "Combinatorial Optimization"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.vibrating_path_graph_coloring:e5597c7f3c12"
      platform    = "linux/amd64"
      source_path = "/home/workspace/vibrating_path"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.vibrating_path_graph_coloring:e5597c7f3c12"
    }
    network_need = "none"
  }

  submission {
    include = [
      "solution.py",
    ]
    exclude = [
      "tests",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 600
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
