{
  "admission": "quarantined",
  "evaluation": {
    "mode": "batch",
    "source_command": "python3 /tmp/eval_dcss.py",
    "source_game_server_command": null,
    "timeout_sec": 1100
  },
  "image": {
    "digest_resolution": "required_at_task_lock",
    "platform": "linux/amd64",
    "ref": "docker.io/seededge/edgebench.judge.dcss_dungeon_ai:db79574e3c30"
  },
  "kind": "oci",
  "requirements": [
    "oci_judge_admission"
  ],
  "schema": "a3s-bench/judge-source/v1",
  "source_result": {
    "kind": "legacy_stdout",
    "parser": "structured_json",
    "rescale_hint": {
      "baseline": 400.0,
      "kind": "log1p_max",
      "upper": 50000.0
    },
    "score_direction": "maximize",
    "selection_hint": "score_first",
    "target_metric": "score"
  },
  "workspace": {
    "source_path": "/home/dcss_agent",
    "submission_exclude": [
      ".git"
    ],
    "submission_paths": [
      "my_bot.rc",
      "my_bot_include.rc"
    ]
  }
}
