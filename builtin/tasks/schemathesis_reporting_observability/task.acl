# Third-party source details: ../../provenance/edgebench.json
bench "schemathesis_reporting_observability" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Schemathesis Reporting Observability"
  category    = "Systems & Software Engineering"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.schemathesis_reporting_observability:cd6879e59e62"
      platform    = "linux/amd64"
      source_path = "/app"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.schemathesis_reporting_observability:cd6879e59e62"
    }
    network_need = "none"
  }

  submission {
    include = [
      ".",
    ]
    exclude = [
      ".git",
      "__pycache__",
      "*.pyc",
      "*.egg-info",
      ".eggs",
      "*.so",
      "TODO.md",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 1800
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
