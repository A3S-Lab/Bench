# Third-party source details: ../../provenance/edgebench.json
bench "integer_compression_codec" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Integer Compression Codec"
  category    = "Systems & Software Engineering"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.integer_compression_codec:fa3895856662"
      platform    = "linux/amd64"
      source_path = "/home/workspace/integer-compression-codec"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.integer_compression_codec:fa3895856662"
    }
    network_need = "none"
  }

  submission {
    include = [
      "include/",
      "src/",
      "Makefile",
    ]
    exclude = [
      "**/__pycache__",
      "outputs",
      "data",
      ".judge-bin",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 2400
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
