# Third-party source details: ../../provenance/edgebench.json
bench "new_foundations_consistency" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "New Foundations Consistency"
  category    = "Formal Math & Theorem Proving"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.new_foundations_consistency:9fdeea94c0b5"
      platform    = "linux/amd64"
      source_path = "/home/workspace/"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.new_foundations_consistency:9fdeea94c0b5"
    }
    network_need = "none"
  }

  submission {
    include = [
      "se-bmk-intern/con-nf",
    ]
    exclude = [
      "se-bmk-intern/con-nf/.lake",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 2400
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
