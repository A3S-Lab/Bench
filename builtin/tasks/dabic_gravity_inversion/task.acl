# Third-party source details: ../../provenance/edgebench.json
bench "dabic_gravity_inversion" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Dabic Gravity Inversion"
  category    = "Scientific Problems & ML"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.dabic_gravity_inversion:85db0aba8a5f"
      platform    = "linux/amd64"
      source_path = "/home/workspace/dabic_gravity_vinton"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.dabic_gravity_inversion:85db0aba8a5f"
    }
    network_need = "none"
  }

  submission {
    include = [
      "outputs/",
    ]
    exclude = [
      "tests",
      "__pycache__",
      "*.pyc",
      "*.npy",
      ".ipynb_checkpoints",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 21600
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
