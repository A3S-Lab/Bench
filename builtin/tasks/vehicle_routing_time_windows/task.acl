# Third-party source details: ../../provenance/edgebench.json
bench "vehicle_routing_time_windows" {
  schema  = "a3s-bench/task/v1"
  version = "0.1.0"

  name        = "Vehicle Routing Time Windows"
  category    = "Combinatorial Optimization"
  description = "Complete the task described in public/prompt.md."

  workspace {
    oci {
      ref         = "docker.io/seededge/edgebench.work.vehicle_routing_time_windows:53214fda231b"
      platform    = "linux/amd64"
      source_path = "/home/workspace/task_cvrptw_905da6dd/workspace"
    }
  }

  work {
    image {
      ref = "docker.io/seededge/edgebench.work.vehicle_routing_time_windows:53214fda231b"
    }
    network_need = "none"
  }

  submission {
    include = [
      "src/",
      "include/",
      "Makefile",
    ]
    exclude = [
      "instances",
      "internal",
      "__MACOSX",
      ".DS_Store",
    ]
  }

  judge {
    asset                = "private/judge"
    solution_timeout_sec = 1200
  }

  metric "score" {
    type                   = "ratio"
    role                   = "primary"
    direction              = "maximize"
    min                    = 0
    max                    = 1
    normalization          = "linear_range_v1"
    solution_failure_value = "0"
    public_report          = true
  }
}
